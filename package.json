{
  "name": "google-chrome",
  "version": "2.0.4",
  "description": "Google Chrome — a desktop web browser with native screen-capture protection",
  "main": "dist-electron/main.js",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "dist": "pnpm run build && electron-builder",
    "dist:ci": "pnpm run build && electron-builder --publish never",
    "postinstall": "node node_modules/electron/install.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "build": {
    "appId": "com.google.Chrome",
    "productName": "Google Chrome",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.ico",
      "build/icon.png"
    ],
    "icon": "build/icon.png",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "CodeByStella",
      "repo": "13-13-browser",
      "private": false,
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
